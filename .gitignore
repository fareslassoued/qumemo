# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only docs
CLAUDE.md
AGENTS.md
PLAN.md
FIX_SUMMARY.md
PIPELINE.md
ASR_FEATURE_PLAN.md

# Quran audio files (large - download on demand)
/public/audio/*.mp3

# Keep the audio directory structure but ignore MP3 files
!/public/audio/.gitkeep

# Aligner pipeline data (regenerable)
tools/aligner/dataset/
tools/aligner/cache/
tools/aligner/output/*.bak

# Reference PDFs (personal)
*.pdf

# Misc screenshots
image.png

# ASR eval reports (generated)
tools/aligner/reports/
