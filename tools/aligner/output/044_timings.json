{
  "surah_no": 44,
  "surah_name_ar": "الدُّخان",
  "surah_name_en": "Ad-Dukhān",
  "ayah_count": 56,
  "ayahs": [
    {
      "id": 4399,
      "aya_no": 1,
      "aya_text": "حَمِٓۖ وَالْكِتَٰبِ اِ۬لْمُبِينِ ١",
      "start_time": 5.52,
      "end_time": 19.028,
      "word_timings": []
    },
    {
      "id": 4400,
      "aya_no": 2,
      "aya_text": "إِنَّا أَنزَلْنَٰهُ فِے لَيْلَةٖ مُّبَٰرَكَةٍۖ إِنَّا كُنَّا مُنذِرِينَۖ ٢",
      "start_time": 19.028,
      "end_time": 32.535,
      "word_timings": []
    },
    {
      "id": 4401,
      "aya_no": 3,
      "aya_text": "فِيهَا يُفْرَقُ كُلُّ أَمْرٍ حَكِيمٍ ٣",
      "start_time": 34.87,
      "end_time": 40.54,
      "word_timings": []
    },
    {
      "id": 4402,
      "aya_no": 4,
      "aya_text": "أَمْراٗ مِّنْ عِندِنَاۖ إِنَّا كُنَّا مُرْسِلِينَ ٤",
      "start_time": 43.345,
      "end_time": 54.19,
      "word_timings": []
    },
    {
      "id": 4403,
      "aya_no": 5,
      "aya_text": "رَحْمَةٗ مِّن رَّبِّكَۖ إِنَّهُۥ هُوَ اَ۬لسَّمِيعُ اُ۬لْعَلِيمُۖ ٥",
      "start_time": 56.4,
      "end_time": 67.095,
      "word_timings": []
    },
    {
      "id": 4404,
      "aya_no": 6,
      "aya_text": "رَبُّ اُ۬لسَّمَٰوَٰتِ وَالْأَرْضِ وَمَا بَيْنَهُمَا إِن كُنتُم مُّوقِنِينَۖ ٦",
      "start_time": 69.87,
      "end_time": 76.9,
      "word_timings": []
    },
    {
      "id": 4405,
      "aya_no": 7,
      "aya_text": "لَا إِلَٰهَ إِلَّا هُوَۖ يُحْيِۦ وَيُمِيتُۖ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ اُ۬لْأَوَّلِينَۖ ٧",
      "start_time": 79.39,
      "end_time": 84.85,
      "word_timings": []
    },
    {
      "id": 4406,
      "aya_no": 8,
      "aya_text": "بَلْ هُمْ فِے شَكّٖ يَلْعَبُونَۖ ٨",
      "start_time": 87.535,
      "end_time": 93.955,
      "word_timings": []
    },
    {
      "id": 4407,
      "aya_no": 9,
      "aya_text": "فَارْتَقِبْ يَوْمَ تَأْتِے اِ۬لسَّمَآءُ بِدُخَانٖ مُّبِينٖ ٩",
      "start_time": 96.195,
      "end_time": 104.04,
      "word_timings": []
    },
    {
      "id": 4408,
      "aya_no": 10,
      "aya_text": "يَغْشَى اَ۬لنَّاسَۖ هَٰذَا عَذَابٌ أَلِيمٞۖ ١٠",
      "start_time": 106.51,
      "end_time": 111.73,
      "word_timings": []
    },
    {
      "id": 4409,
      "aya_no": 11,
      "aya_text": "رَّبَّنَا اَ۪كْشِفْ عَنَّا اَ۬لْعَذَابَ إِنَّا مُؤْمِنُونَۖ ١١",
      "start_time": 113.47,
      "end_time": 122.55,
      "word_timings": []
    },
    {
      "id": 4410,
      "aya_no": 12,
      "aya_text": "أَنَّىٰ لَهُمُ اُ۬لذِّكْرَىٰ وَقَدْ جَآءَهُمْ رَسُولٞ مُّبِينٞ ١٢",
      "start_time": 128.56,
      "end_time": 143.17,
      "word_timings": []
    },
    {
      "id": 4411,
      "aya_no": 13,
      "aya_text": "ثُمَّ تَوَلَّوْاْ عَنْهُ وَقَالُواْ مُعَلَّمٞ مَّجْنُونٌۖ ١٣",
      "start_time": 145.56,
      "end_time": 156.215,
      "word_timings": []
    },
    {
      "id": 4412,
      "aya_no": 14,
      "aya_text": "إِنَّا كَاشِفُواْ اُ۬لْعَذَابِ قَلِيلاًۖ إِنَّكُمْ عَآئِدُونَۖ ١٤",
      "start_time": 158.415,
      "end_time": 167.345,
      "word_timings": []
    },
    {
      "id": 4413,
      "aya_no": 15,
      "aya_text": "يَوْمَ نَبْطِشُ اُ۬لْبَطْشَةَ اَ۬لْكُبْرَىٰۖ إِنَّا مُنتَقِمُونَۖ ١٥",
      "start_time": 170.42,
      "end_time": 176.44,
      "word_timings": []
    },
    {
      "id": 4414,
      "aya_no": 16,
      "aya_text": "وَلَقَدْ فَتَنَّا قَبْلَهُمْ قَوْمَ فِرْعَوْنَ وَجَآءَهُمْ رَسُولٞ كَرِيمٌ ١٦",
      "start_time": 186.675,
      "end_time": 196.195,
      "word_timings": []
    },
    {
      "id": 4415,
      "aya_no": 17,
      "aya_text": "أَنْ أَدُّواْ إِلَيَّ عِبَادَ اَ۬للَّهِ إِنِّے لَكُمْ رَسُولٌ أَمِينٞ ١٧",
      "start_time": 199.335,
      "end_time": 212.525,
      "word_timings": []
    },
    {
      "id": 4416,
      "aya_no": 18,
      "aya_text": "وَأَن لَّا تَعْلُواْ عَلَى اَ۬للَّهِ إِنِّيَ ءَاتِيكُم بِسُلْطَٰنٖ مُّبِينٖ ١٨",
      "start_time": 215.015,
      "end_time": 220.65,
      "word_timings": []
    },
    {
      "id": 4417,
      "aya_no": 19,
      "aya_text": "وَإِنِّے عُذْتُ بِرَبِّے وَرَبِّكُمْ أَن تَرْجُمُونِ ١٩",
      "start_time": 230.55,
      "end_time": 245.045,
      "word_timings": []
    },
    {
      "id": 4418,
      "aya_no": 20,
      "aya_text": "وَإِن لَّمْ تُؤْمِنُواْ لِي فَاعْتَزِلُونِۖ ٢٠",
      "start_time": 247.47,
      "end_time": 256.395,
      "word_timings": []
    },
    {
      "id": 4419,
      "aya_no": 21,
      "aya_text": "فَدَعَا رَبَّهُۥ أَنَّ هَٰؤُلَآءِ قَوْمٞ مُّجْرِمُونَۖ ٢١",
      "start_time": 258.61,
      "end_time": 264.115,
      "word_timings": []
    },
    {
      "id": 4420,
      "aya_no": 22,
      "aya_text": "فَاسْرِ بِعِبَادِے لَيْلاً إِنَّكُم مُّتَّبَعُونَ ٢٢",
      "start_time": 267.51,
      "end_time": 278.275,
      "word_timings": []
    },
    {
      "id": 4421,
      "aya_no": 23,
      "aya_text": "وَاتْرُكِ اِ۬لْبَحْرَ رَهْواًۖ إِنَّهُمْ جُندٞ مُّغْرَقُونَۖ ٢٣",
      "start_time": 280.57,
      "end_time": 288.96,
      "word_timings": []
    },
    {
      "id": 4422,
      "aya_no": 24,
      "aya_text": "۞ كَمْ تَرَكُواْ مِن جَنَّٰتٖ وَعُيُونٖ ٢٤",
      "start_time": 296.91,
      "end_time": 302.915,
      "word_timings": []
    },
    {
      "id": 4423,
      "aya_no": 25,
      "aya_text": "وَزُرُوعٖ وَمَقَامٖ كَرِيمٖ ٢٥",
      "start_time": 305.855,
      "end_time": 313.31,
      "word_timings": []
    },
    {
      "id": 4424,
      "aya_no": 26,
      "aya_text": "وَنَعْمَةٖ كَانُواْ فِيهَا فَٰكِهِينَۖ ٢٦",
      "start_time": 315.695,
      "end_time": 321.43,
      "word_timings": []
    },
    {
      "id": 4425,
      "aya_no": 27,
      "aya_text": "كَذَٰلِكَۖ وَأَوْرَثْنَٰهَا قَوْماً ءَاخَرِينَۖ ٢٧",
      "start_time": 323.405,
      "end_time": 330.415,
      "word_timings": []
    },
    {
      "id": 4426,
      "aya_no": 28,
      "aya_text": "فَمَا بَكَتْ عَلَيْهِمُ اُ۬لسَّمَآءُ وَالْأَرْضُ وَمَا كَانُواْ مُنظَرِينَۖ ٢٨",
      "start_time": 335.52,
      "end_time": 341.745,
      "word_timings": []
    },
    {
      "id": 4427,
      "aya_no": 29,
      "aya_text": "وَلَقَدْ نَجَّيْنَا بَنِے إِسْرَآءِيلَ مِنَ اَ۬لْعَذَابِ اِ۬لْمُهِينِ ٢٩",
      "start_time": 344.965,
      "end_time": 357.445,
      "word_timings": []
    },
    {
      "id": 4428,
      "aya_no": 30,
      "aya_text": "مِن فِرْعَوْنَۖ إِنَّهُۥ كَانَ عَالِياٗ مِّنَ اَ۬لْمُسْرِفِينَۖ ٣٠",
      "start_time": 360.835,
      "end_time": 371.915,
      "word_timings": []
    },
    {
      "id": 4429,
      "aya_no": 31,
      "aya_text": "وَلَقَدِ اِ۪خْتَرْنَٰهُمْ عَلَىٰ عِلْمٍ عَلَى اَ۬لْعَٰلَمِينَ ٣١",
      "start_time": 373.765,
      "end_time": 384.95,
      "word_timings": []
    },
    {
      "id": 4430,
      "aya_no": 32,
      "aya_text": "وَءَاتَيْنَٰهُم مِّنَ اَ۬لْأٓيَٰتِ مَا فِيهِ بَلَٰٓؤٞاْ مُّبِينٌۖ ٣٢",
      "start_time": 387.81,
      "end_time": 395.59,
      "word_timings": []
    },
    {
      "id": 4431,
      "aya_no": 33,
      "aya_text": "إِنَّ هَٰؤُلَآءِ لَيَقُولُونَ إِنْ هِيَ إِلَّا مَوْتَتُنَا اَ۬لْأُولَىٰ وَمَا نَحْنُ بِمُنشَرِينَ ٣٣",
      "start_time": 397.575,
      "end_time": 409.105,
      "word_timings": []
    },
    {
      "id": 4432,
      "aya_no": 34,
      "aya_text": "فَأْتُواْ بِـَٔابَآئِنَا إِن كُنتُمْ صَٰدِقِينَۖ ٣٤",
      "start_time": 412.475,
      "end_time": 429.815,
      "word_timings": []
    },
    {
      "id": 4433,
      "aya_no": 35,
      "aya_text": "أَهُمْ خَيْرٌ أَمْ قَوْمُ تُبَّعٖۖ وَالذِينَ مِن قَبْلِهِمْ أَهْلَكْنَٰهُمْۖ إِنَّهُمْ كَانُواْ مُجْرِمِينَۖ ٣٥",
      "start_time": 432.655,
      "end_time": 442.495,
      "word_timings": []
    },
    {
      "id": 4434,
      "aya_no": 36,
      "aya_text": "وَمَا خَلَقْنَا اَ۬لسَّمَٰوَٰتِ وَالْأَرْضَ وَمَا بَيْنَهُمَا لَٰعِبِينَۖ ٣٦",
      "start_time": 444.65,
      "end_time": 454.57,
      "word_timings": []
    },
    {
      "id": 4435,
      "aya_no": 37,
      "aya_text": "مَا خَلَقْنَٰهُمَا إِلَّا بِالْحَقِّۖ وَلَٰكِنَّ أَكْثَرَهُمْ لَا يَعْلَمُونَۖ ٣٧",
      "start_time": 456.52,
      "end_time": 464.435,
      "word_timings": []
    },
    {
      "id": 4436,
      "aya_no": 38,
      "aya_text": "إِنَّ يَوْمَ اَ۬لْفَصْلِ مِيقَٰتُهُمْ أَجْمَعِينَ ٣٨",
      "start_time": 468.715,
      "end_time": 479.745,
      "word_timings": []
    },
    {
      "id": 4437,
      "aya_no": 39,
      "aya_text": "يَوْمَ لَا يُغْنِے مَوْلىً عَن مَّوْلىٗ شَئْاٗ وَلَا هُمْ يُنصَرُونَ ٣٩",
      "start_time": 482.035,
      "end_time": 494.945,
      "word_timings": []
    },
    {
      "id": 4438,
      "aya_no": 40,
      "aya_text": "إِلَّا مَن رَّحِمَ اَ۬للَّهُۖ إِنَّهُۥ هُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ٤٠",
      "start_time": 498.135,
      "end_time": 506.01,
      "word_timings": []
    },
    {
      "id": 4439,
      "aya_no": 41,
      "aya_text": "إِنَّ شَجَرَتَ اَ۬لزَّقُّومِ طَعَامُ اُ۬لْأَثِيمِ ٤١",
      "start_time": 508.48,
      "end_time": 521.205,
      "word_timings": []
    },
    {
      "id": 4440,
      "aya_no": 42,
      "aya_text": "كَالْمُهْلِ تَغْلِے فِے اِ۬لْبُطُونِ ٤٢",
      "start_time": 523.385,
      "end_time": 535.12,
      "word_timings": []
    },
    {
      "id": 4441,
      "aya_no": 43,
      "aya_text": "كَغَلْيِ اِ۬لْحَمِيمِۖ ٤٣",
      "start_time": 538.77,
      "end_time": 546.515,
      "word_timings": []
    },
    {
      "id": 4442,
      "aya_no": 44,
      "aya_text": "خُذُوهُ فَاعْتُلُوهُ إِلَىٰ سَوَآءِ اِ۬لْجَحِيمِ ٤٤",
      "start_time": 561.03,
      "end_time": 569.125,
      "word_timings": []
    },
    {
      "id": 4443,
      "aya_no": 45,
      "aya_text": "ثُمَّ صُبُّواْ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ اِ۬لْحَمِيمِ ٤٥",
      "start_time": 571.21,
      "end_time": 580.195,
      "word_timings": []
    },
    {
      "id": 4444,
      "aya_no": 46,
      "aya_text": "ذُقْۖ إِنَّكَ أَنتَ اَ۬لْعَزِيزُ اُ۬لْكَرِيمُۖ ٤٦",
      "start_time": 583.09,
      "end_time": 589.94,
      "word_timings": []
    },
    {
      "id": 4445,
      "aya_no": 47,
      "aya_text": "إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَۖ ٤٧",
      "start_time": 591.38,
      "end_time": 599.745,
      "word_timings": []
    },
    {
      "id": 4446,
      "aya_no": 48,
      "aya_text": "إِنَّ اَ۬لْمُتَّقِينَ فِے مُقَامٍ أَمِينٖ ٤٨",
      "start_time": 602.53,
      "end_time": 609.925,
      "word_timings": []
    },
    {
      "id": 4447,
      "aya_no": 49,
      "aya_text": "فِے جَنَّٰتٖ وَعُيُونٖ ٤٩",
      "start_time": 611.735,
      "end_time": 617.05,
      "word_timings": []
    },
    {
      "id": 4448,
      "aya_no": 50,
      "aya_text": "يَلْبَسُونَ مِن سُندُسٖ وَإِسْتَبْرَقٖ مُّتَقَٰبِلِينَۖ ٥٠",
      "start_time": 619.09,
      "end_time": 630.12,
      "word_timings": []
    },
    {
      "id": 4449,
      "aya_no": 51,
      "aya_text": "كَذَٰلِكَۖ وَزَوَّجْنَٰهُم بِحُورٍ عِينٖۖ ٥١",
      "start_time": 631.93,
      "end_time": 640.75,
      "word_timings": []
    },
    {
      "id": 4450,
      "aya_no": 52,
      "aya_text": "يَدْعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَۖ ٥٢",
      "start_time": 643.55,
      "end_time": 651.94,
      "word_timings": []
    },
    {
      "id": 4451,
      "aya_no": 53,
      "aya_text": "لَا يَذُوقُونَ فِيهَا اَ۬لْمَوْتَۖ إِلَّا اَ۬لْمَوْتَةَ اَ۬لْأُولَىٰۖ وَوَقَيٰهُمْ عَذَابَ اَ۬لْجَحِيمِ ٥٣",
      "start_time": 654.25,
      "end_time": 663.58,
      "word_timings": []
    },
    {
      "id": 4452,
      "aya_no": 54,
      "aya_text": "فَضْلاٗ مِّن رَّبِّكَۖ ذَٰلِكَ هُوَ اَ۬لْفَوْزُ اُ۬لْعَظِيمُۖ ٥٤",
      "start_time": 672.395,
      "end_time": 682.45,
      "word_timings": []
    },
    {
      "id": 4453,
      "aya_no": 55,
      "aya_text": "فَإِنَّمَا يَسَّرْنَٰهُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّرُونَۖ ٥٥",
      "start_time": 684.83,
      "end_time": 696.0,
      "word_timings": []
    },
    {
      "id": 4454,
      "aya_no": 56,
      "aya_text": "فَارْتَقِبْۖ إِنَّهُم مُّرْتَقِبُونَۖ ٥٦",
      "start_time": 697.755,
      "end_time": 704.045,
      "word_timings": []
    }
  ]
}